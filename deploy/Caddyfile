movingstuff.duckdns.org, localhost, 127.0.0.1 {
	basic_auth * {
		daniel $2a$14$vEnr6H9gyb5O3hk59WPYNOA347EqE6JfUAKDlMvLLqOigBHeq.ZhC
	}

	# Caddy does not compress by default; compress text assets and JSON.
	encode zstd gzip

	handle /api/* {
		reverse_proxy localhost:5000
	}

	handle {
		root * /opt/boxtracker/frontend/dist

		# Vite content-hashes everything under /assets, so those files never
		# change in place — cache them for a year and skip revalidation. The
		# HTML entry point must stay uncached so new deploys are picked up.
		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"
		@html path / /index.html
		header @html Cache-Control "no-cache"

		file_server
		try_files {path} {path}/ /index.html
	}
}
