{
  "name": "boxtracker",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "dotnet fable watch --cwd src/Client --run npx vite",
    "build": "dotnet fable --cwd src/Client && cd src/Client && npx vite build",
    "build:client": "dotnet fable --cwd src/Client"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "use-sync-external-store": "^1.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.7",
    "daisyui": "^5.0.35",
    "tailwindcss": "^4.1.7",
    "vite": "^6.3.5"
  }
}
